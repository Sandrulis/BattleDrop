# =============================================================================
# BattleDrop — environment variables
# Copy to .env.local and fill in values from Supabase + Vercel.
# =============================================================================

# --- Supabase (required) ---
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server only — NEVER expose in browser or commit real value to git
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- App URL (required for auth redirects) ---
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (Vercel): https://your-app.vercel.app

# --- Optional: GitHub OAuth (only if you enable GitHub login in Supabase) ---
# Create OAuth App: https://github.com/settings/developers
# Then add Client ID + Secret in Supabase → Authentication → Providers → GitHub
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
